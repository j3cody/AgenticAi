# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# For MongoDB Atlas (recommended): mongodb+srv://<username>:<password>@cluster.mongodb.net/mental-health-assistant
# For local MongoDB: mongodb://localhost:27017/mental-health-assistant
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/mental-health-assistant

# JWT Secret (change this in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Gemini LLM Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.0-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
